appearance Appearance {   
material Material {   
  diffuseColor 1.0 1. 1.   
  specularColor 0. 0. 0.   
  emissiveColor 0.1 0.1 0.1   
  ambientIntensity 1.   
  shininess  0.   
  transparency 0.0   
} }   
}    ### Shape   
   
   
#### --------- Define the headlight for general lighting --------------   
DEF navLight NavigationInfo {   
      headlight TRUE
      type "EXAMINE"	   
}   
   
DEF lightCond Script {   
###  eventIn SFBool dl_isActive   
  eventIn SFBool hl_isActive   
###  field SFNode sunLight USE sunLight   
  field SFNode navLight USE navLight   
  url "javascript:   
    }    
   
    function hl_isActive(){   
      navLight.headlight = TRUE;   
    }   
  "   
}   
   
### ---------------------------------------------------------------   
   
### ---------------------------------------------------------------   
##### Group for Headlight illumination   
   
Group { children [    
  DEF HL_MY ProximitySensor {   
     center  0 -1.5e3 0   
     size     1e2 1e2 1e2   
  },   
  Viewpoint {   
    description "View from -Y Direction"   
    fieldOfView 0.0015   
    position 0 -1.5e3 0   
    orientation 1 0 0 1.5708   
  }   
  ROUTE HL_MY.isActive TO lightCond.hl_isActive   
]}   
   
Group { children [    
  DEF HL_PY ProximitySensor {   
     center  0 1.5e3 0   
     size     1e2 1e2 1e2   
  },   
  Viewpoint {   
    description "View from +Y Direction"   
    fieldOfView 0.0015   
    position 0 1.5e3 0   
    orientation 1 0 0 -1.5708   
  }   
  ROUTE HL_PY.isActive TO lightCond.hl_isActive   
]}   
     
Group { children [    
  DEF HL_MX ProximitySensor {   
     center  -1.5e3 0 0   
     size     1e2 1e2 1e2   
  },   
  Viewpoint {   
    description "View from -X Direction"   
    fieldOfView 0.0015   
    position -1.5e3 0 0   
    orientation 0 1 0 -1.5708   
  },   
  ROUTE HL_MX.isActive TO lightCond.hl_isActive   
]}   
     
Group { children [    
  DEF HL_PX ProximitySensor {   
     center  1.5e3 0 0   
     size     1e2 1e2 1e2  
  },   
  Viewpoint {   
    description "View from +X Direction"   
    fieldOfView 0.0015   
    position 1.5e3 0 0   
    orientation 0 1 0 1.5708 
  }   
  ROUTE HL_PX.isActive TO lightCond.hl_isActive   
]}   
     
Group { children [    
  DEF HL_PZ ProximitySensor {   
     center 0 0 1.5e3   
     size     1.e2 1.e2 1.e2   
   },   
  Viewpoint {   
    description "View above Positive Pole (+Z)"   
    fieldOfView 0.0015   
    position 0 0 1.5e3   
    orientation 0. 0. 1. 0   
  }   
  ROUTE HL_PZ.isActive TO lightCond.hl_isActive   
]}   
     
Group { children [    
  DEF HL_MZ ProximitySensor {   
     center  0. 0. -1.5e3   
     size     1.e2 1.e2 1.e2   
  },   
  Viewpoint {   
    description "View above Negative Pole (-Z)"   
    fieldOfView 0.0015   
    position 0. 0. -1.5e3   
    orientation 0. 1. 0. -3.14159   
  }   
  ROUTE HL_MZ.isActive TO lightCond.hl_isActive   
]}   
     
